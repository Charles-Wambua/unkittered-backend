{
  "info": {
    "title": "Unkittered API",
    "description": "Dating app backend API",
    "version": "1.0.0",
    "baseUrl": "http://localhost:8080/v1"
  },
  "authentication": {
    "type": "JWT Bearer Token",
    "header": "Authorization: Bearer <token>",
    "obtainFrom": [
      "POST /v1/auth/register",
      "POST /v1/auth/login",
      "POST /v1/auth/oauth"
    ]
  },
  "endpoints": {
    "public": {
      "description": "Endpoints that require no authentication",
      "items": [
        {
          "method": "POST",
          "path": "/v1/auth/register",
          "status": 201,
          "body": {
            "email": "string",
            "password": "string",
            "displayName": "string"
          },
          "response": {
            "token": "string",
            "user": {
              "id": "uuid",
              "email": "string",
              "displayName": "string",
              "subscriptionTier": "free|premium|vip",
              "onboardingComplete": "boolean"
            }
          }
        },
        {
          "method": "POST",
          "path": "/v1/auth/login",
          "status": 200,
          "body": {
            "email": "string",
            "password": "string"
          },
          "response": {
            "token": "string",
            "user": "object"
          }
        },
        {
          "method": "POST",
          "path": "/v1/auth/oauth",
          "status": 200,
          "body": {
            "provider": "google|apple|facebook",
            "token": "string"
          },
          "response": {
            "token": "string",
            "user": "object"
          }
        },
        {
          "method": "POST",
          "path": "/v1/auth/reset-password",
          "status": 200,
          "body": {
            "email": "string",
            "newPassword": "string"
          },
          "response": {
            "token": "string",
            "user": "object"
          }
        },
        {
          "method": "POST",
          "path": "/v1/auth/logout",
          "status": 204,
          "response": "empty"
        }
      ]
    },
    "discovery": {
      "description": "Profile discovery and browsing",
      "auth": true,
      "items": [
        {
          "method": "GET",
          "path": "/v1/discover",
          "status": 200,
          "description": "Get 30 profiles, Redis cached 60s",
          "response": {
            "profiles": [
              {
                "id": "uuid",
                "name": "string",
                "age": "number",
                "imageUrl": "string",
                "bio": "string",
                "interests": ["string"],
                "isVerified": "boolean",
                "isOnline": "boolean"
              }
            ]
          }
        }
      ]
    },
    "interactions": {
      "description": "Likes, passes, matches",
      "auth": true,
      "items": [
        {
          "method": "POST",
          "path": "/v1/likes",
          "status": 200,
          "body": {
            "profileId": "uuid"
          },
          "response": {
            "isMatch": "boolean",
            "matchId": "uuid|null"
          }
        },
        {
          "method": "POST",
          "path": "/v1/super-likes",
          "status": 200,
          "body": {
            "profileId": "uuid"
          },
          "response": {
            "isMatch": "boolean",
            "matchId": "uuid|null"
          }
        },
        {
          "method": "POST",
          "path": "/v1/passes",
          "status": 204,
          "body": {
            "profileId": "uuid"
          },
          "response": "empty"
        },
        {
          "method": "GET",
          "path": "/v1/likes/received",
          "status": 200,
          "response": {
            "profiles": "array<ProfileDto>"
          }
        }
      ]
    },
    "messaging": {
      "description": "Matches, conversations, messages",
      "auth": true,
      "items": [
        {
          "method": "GET",
          "path": "/v1/matches",
          "status": 200,
          "response": {
            "matches": [
              {
                "id": "uuid",
                "profile": "object",
                "createdAt": "ISO8601",
                "lastMessageAt": "ISO8601"
              }
            ]
          }
        },
        {
          "method": "GET",
          "path": "/v1/conversations",
          "status": 200,
          "response": {
            "conversations": [
              {
                "matchId": "uuid",
                "profile": "object",
                "lastMessage": "string",
                "unreadCount": "number"
              }
            ]
          }
        },
        {
          "method": "GET",
          "path": "/v1/conversations/{matchId}/messages",
          "status": 200,
          "response": {
            "messages": [
              {
                "id": "uuid",
                "isMe": "boolean",
                "text": "string",
                "createdAt": "ISO8601",
                "readAt": "ISO8601|null"
              }
            ]
          }
        },
        {
          "method": "POST",
          "path": "/v1/conversations/{matchId}/messages",
          "status": 200,
          "body": {
            "text": "string"
          },
          "response": {
            "id": "uuid",
            "isMe": "boolean",
            "text": "string",
            "createdAt": "ISO8601"
          }
        },
        {
          "method": "DELETE",
          "path": "/v1/matches/{matchId}",
          "status": 204,
          "response": "empty"
        }
      ]
    },
    "profile": {
      "description": "User account and profile management",
      "auth": true,
      "items": [
        {
          "method": "GET",
          "path": "/v1/me",
          "status": 200,
          "response": {
            "id": "uuid",
            "email": "string",
            "displayName": "string",
            "subscriptionTier": "string",
            "onboardingComplete": "boolean"
          }
        },
        {
          "method": "GET",
          "path": "/v1/me/profile",
          "status": 200,
          "response": {
            "userId": "uuid",
            "name": "string",
            "age": "number",
            "bio": "string",
            "location": "string",
            "interests": ["string"],
            "isVerified": "boolean",
            "isOnline": "boolean"
          }
        },
        {
          "method": "PUT",
          "path": "/v1/me/profile",
          "status": 200,
          "body": {
            "name": "string",
            "age": "number",
            "bio": "string",
            "interests": ["string"],
            "showActivity": "boolean",
            "hideDistance": "boolean",
            "incognitoMode": "boolean"
          },
          "response": "ProfileDto"
        },
        {
          "method": "POST",
          "path": "/v1/me/onboarding/complete",
          "status": 200,
          "response": "UserDto"
        },
        {
          "method": "POST",
          "path": "/v1/me/photos",
          "status": 200,
          "contentType": "multipart/form-data",
          "body": {
            "file": "binary"
          },
          "response": {
            "url": "string"
          }
        }
      ]
    },
    "safety": {
      "description": "Blocks, reports, moderation",
      "auth": true,
      "items": [
        {
          "method": "POST",
          "path": "/v1/blocks",
          "status": 204,
          "body": {
            "profileId": "uuid"
          },
          "response": "empty"
        },
        {
          "method": "DELETE",
          "path": "/v1/blocks/{profileId}",
          "status": 204,
          "response": "empty"
        },
        {
          "method": "GET",
          "path": "/v1/blocks",
          "status": 200,
          "response": {
            "profiles": "array<ProfileDto>"
          }
        },
        {
          "method": "POST",
          "path": "/v1/reports",
          "status": 204,
          "body": {
            "profileId": "uuid",
            "reason": "string",
            "details": "string"
          },
          "response": "empty"
        }
      ]
    },
    "subscriptions": {
      "description": "Subscription and premium features",
      "auth": true,
      "items": [
        {
          "method": "GET",
          "path": "/v1/subscriptions/me",
          "status": 200,
          "response": {
            "tier": "free|premium|vip",
            "renewalDate": "ISO8601",
            "isCanceled": "boolean"
          }
        },
        {
          "method": "POST",
          "path": "/v1/subscriptions/boost",
          "status": 200,
          "response": {
            "expiresAt": "ISO8601",
            "boostCount": "number"
          }
        },
        {
          "method": "POST",
          "path": "/v1/subscriptions/verify",
          "status": 200,
          "body": {
            "productId": "string",
            "receipt": "string"
          },
          "response": {
            "tier": "string",
            "renewalDate": "ISO8601"
          }
        },
        {
          "method": "POST",
          "path": "/v1/subscriptions/cancel",
          "status": 204,
          "response": "empty"
        }
      ]
    },
    "notifications": {
      "description": "Device tokens and notification preferences",
      "auth": true,
      "items": [
        {
          "method": "POST",
          "path": "/v1/devices",
          "status": 204,
          "body": {
            "token": "string",
            "platform": "ios|android"
          },
          "response": "empty"
        },
        {
          "method": "DELETE",
          "path": "/v1/devices/{token}",
          "status": 204,
          "response": "empty"
        },
        {
          "method": "GET",
          "path": "/v1/me/notification-prefs",
          "status": 200,
          "response": {
            "matches": "boolean",
            "messages": "boolean",
            "reminders": "boolean",
            "likes": "boolean"
          }
        },
        {
          "method": "PUT",
          "path": "/v1/me/notification-prefs",
          "status": 200,
          "body": {
            "matches": "boolean",
            "messages": "boolean",
            "reminders": "boolean",
            "likes": "boolean"
          },
          "response": "object"
        }
      ]
    },
    "stories": {
      "description": "User stories (24-hour expiring content)",
      "auth": true,
      "items": [
        {
          "method": "GET",
          "path": "/v1/stories",
          "status": 200,
          "response": {
            "stories": "array<StoryDto>"
          }
        },
        {
          "method": "POST",
          "path": "/v1/me/stories",
          "status": 200,
          "contentType": "multipart/form-data",
          "body": {
            "file": "binary (optional)",
            "text": "string (optional)"
          },
          "response": {
            "id": "uuid",
            "mediaUrl": "string",
            "expiresAt": "ISO8601"
          }
        },
        {
          "method": "DELETE",
          "path": "/v1/me/stories",
          "status": 204,
          "response": "empty"
        }
      ]
    },
    "reels": {
      "description": "Short-form video content",
      "auth": true,
      "items": [
        {
          "method": "GET",
          "path": "/v1/reels",
          "status": 200,
          "response": {
            "reels": "array<ReelDto>"
          }
        },
        {
          "method": "POST",
          "path": "/v1/me/reel",
          "status": 200,
          "contentType": "multipart/form-data",
          "body": {
            "file": "binary (video)",
            "poster": "binary (optional)"
          },
          "response": {
            "id": "uuid",
            "videoUrl": "string",
            "posterUrl": "string"
          }
        },
        {
          "method": "DELETE",
          "path": "/v1/me/reel",
          "status": 204,
          "response": "empty"
        }
      ]
    },
    "meetups": {
      "description": "Meetup scheduling and RSVPs",
      "auth": true,
      "items": [
        {
          "method": "GET",
          "path": "/v1/meetups",
          "status": 200,
          "response": {
            "meetups": "array<MeetupDto>"
          }
        },
        {
          "method": "POST",
          "path": "/v1/meetups",
          "status": 200,
          "body": {
            "title": "string",
            "description": "string",
            "location": "string",
            "latitude": "number",
            "longitude": "number",
            "scheduledAt": "ISO8601"
          },
          "response": "MeetupDto"
        },
        {
          "method": "POST",
          "path": "/v1/meetups/{id}/rsvp",
          "status": 200,
          "response": "MeetupDto"
        },
        {
          "method": "DELETE",
          "path": "/v1/meetups/{id}/rsvp",
          "status": 200,
          "response": "MeetupDto"
        },
        {
          "method": "DELETE",
          "path": "/v1/meetups/{id}",
          "status": 204,
          "response": "empty"
        },
        {
          "method": "POST",
          "path": "/v1/meetups/{id}/report",
          "status": 204,
          "response": "empty"
        }
      ]
    },
    "verification": {
      "description": "Identity verification",
      "auth": true,
      "items": [
        {
          "method": "GET",
          "path": "/v1/me/verification",
          "status": 200,
          "response": {
            "status": "not_started|pending|approved|rejected",
            "submittedAt": "ISO8601|null",
            "approvedAt": "ISO8601|null"
          }
        },
        {
          "method": "POST",
          "path": "/v1/me/verification",
          "status": 200,
          "contentType": "multipart/form-data",
          "body": {
            "file": "binary (ID photo)"
          },
          "response": {
            "status": "pending",
            "submittedAt": "ISO8601"
          }
        }
      ]
    },
    "admin": {
      "description": "Admin-only endpoints",
      "auth": true,
      "adminOnly": true,
      "items": [
        {
          "method": "GET",
          "path": "/v1/admin/stats",
          "status": 200,
          "response": {
            "totalUsers": "number",
            "newUsersToday": "number",
            "activeUsers24h": "number"
          }
        },
        {
          "method": "GET",
          "path": "/v1/admin/me",
          "status": 200,
          "response": {
            "isAdmin": "boolean"
          }
        },
        {
          "method": "GET",
          "path": "/v1/admin/verifications",
          "status": 200,
          "response": {
            "verifications": "array"
          }
        },
        {
          "method": "POST",
          "path": "/v1/admin/verifications/{userId}/approve",
          "status": 204,
          "response": "empty"
        },
        {
          "method": "POST",
          "path": "/v1/admin/verifications/{userId}/reject",
          "status": 204,
          "response": "empty"
        },
        {
          "method": "GET",
          "path": "/v1/admin/reports",
          "status": 200,
          "response": {
            "reports": "array<ReportDto>"
          }
        },
        {
          "method": "DELETE",
          "path": "/v1/admin/reports/{type}/{id}",
          "status": 204,
          "response": "empty"
        },
        {
          "method": "POST",
          "path": "/v1/admin/users/{id}/suspend",
          "status": 204,
          "response": "empty"
        },
        {
          "method": "POST",
          "path": "/v1/admin/users/{id}/unsuspend",
          "status": 204,
          "response": "empty"
        },
        {
          "method": "GET",
          "path": "/v1/admin/insights",
          "status": 200,
          "response": "InsightsDto"
        },
        {
          "method": "GET",
          "path": "/v1/admin/live",
          "status": 200,
          "response": "LiveStatsDto"
        },
        {
          "method": "GET",
          "path": "/v1/admin/endpoints",
          "status": 200,
          "response": {
            "endpoints": "array"
          }
        },
        {
          "method": "GET",
          "path": "/v1/admin/system",
          "status": 200,
          "response": "SystemStatusDto"
        }
      ]
    },
    "websocket": {
      "description": "Real-time WebSocket connection",
      "auth": true,
      "items": [
        {
          "method": "WS",
          "path": "/ws/chat?token=<JWT>",
          "status": 101,
          "events": [
            {
              "type": "message",
              "data": {
                "id": "uuid",
                "matchId": "uuid",
                "senderId": "uuid",
                "text": "string",
                "createdAt": "ISO8601"
              }
            },
            {
              "type": "match",
              "data": {
                "matchId": "uuid",
                "profile": "object"
              }
            },
            {
              "type": "typing",
              "data": {
                "matchId": "uuid",
                "senderId": "uuid"
              }
            },
            {
              "type": "presence",
              "data": {
                "userId": "uuid",
                "status": "online|offline"
              }
            }
          ]
        }
      ]
    }
  },
  "statusCodes": {
    "200": "OK",
    "201": "Created",
    "204": "No Content",
    "400": "Bad Request",
    "401": "Unauthorized",
    "403": "Forbidden",
    "404": "Not Found",
    "409": "Conflict",
    "429": "Too Many Requests",
    "500": "Internal Server Error"
  }
}
